# PocketBase
PB_HTTP=0.0.0.0:8090

# PocketBase directories (relative to backend/ when pb.sh runs)
PB_DATA_DIR=./pb_data
PB_MIGRATIONS_DIR=./pb_migrations
PB_HOOKS_DIR=./pb_hooks
PB_URL=http://127.0.0.1:8090

# CORS / Origins
PB_ORIGINS=http://localhost:5173,https://*.app.github.dev,https://*.githubpreview.dev,https://*.gitpod.dev

# Dev niceties
PB_HOOKS_WATCH=true
PB_HOOKS_POOL=15

# Frontend public URL (Gitpod)